# EdTech LMS RPI API Configuration
# Copy this file to .env and fill in your actual values

# RPI API Configuration
FORTYKAPIRPICONFIG={"fortyk":{"api":{"rpi":{"port":3000,"debug":true,"database":{"name":"edtech_lms_rpi","user":"your-db-user","password":"your-db-password","host":"localhost","port":3306}}}}}

# Alternative Environment Variables (if not using FORTYKAPIRPICONFIG)
RPI_PORT=3000
RPI_DB_NAME=edtech_lms_rpi
RPI_DB_USER=your-db-user
RPI_DB_PASSWORD=your-db-password
RPI_DB_HOST=localhost
RPI_DB_PORT=3306

# Application Settings
NODE_ENV=development
LOG_LEVEL=debug
